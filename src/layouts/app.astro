---
import type { Gender } from '@/types';
import { ClientRouter } from 'astro:transitions';
import { Footer } from '@/components/footer';
import { APP_NAME, AUTHOR_NAME, BASE_IMAGE_URL } from '@/constants/global';
import { cn } from '@/utils/classes';
import '@/styles/global.css';

interface Props {
  class?: string;
}

interface Params {
  gender?: Gender;
  group?: string;
  teamName?: string;
  team1?: string;
  team2?: string;
}

const { class: className } = Astro.props;
const { gender, group, teamName, team1, team2 } =
  Astro.params as unknown as Params;

function getDescription() {
  if (team1 && team2) {
    return `Pádel Cantabria - Comparación de equipos ${team1} vs ${team2}`;
  }

  if (teamName) {
    return `Pádel Cantabria - Información del equipo ${teamName}`;
  }

  if (group && gender) {
    return `Pádel Cantabria - Información de la categoría ${group} de ${gender.toLowerCase()}`;
  }

  return 'Pádel Cantabria - mejora la Ui del sitio oficial de la Liga Cántabra de Pádel, fue creada con motivos educativos.';
}

const siteTitle = 'Pádel Cantabria';
const description = getDescription();
const canonicalUrl = Astro.url.href;
const ogImageUrl = new URL(BASE_IMAGE_URL, Astro.url).toString();
---

<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={Astro.url.href} />

    <title>{siteTitle}</title>

    <meta name="description" content={description} />
    <meta name="robots" content="index,follow" />
    <meta name="author" content={AUTHOR_NAME} />
    <meta name="application-name" content={APP_NAME} />
    <meta name="theme-color" content="#0f172a" />
    <link rel="icon" type="image/svg+xml" href="/favicon.png" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={APP_NAME} />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={APP_NAME} />
    <meta property="og:locale" content="es_ES" />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content={siteTitle} />
    <meta property="twitter:description" content={description} />

    <meta property="linkedin:card" content="summary_large_image" />
    <meta property="linkedin:url" content={canonicalUrl} />
    <meta property="linkedin:title" content={siteTitle} />
    <meta property="linkedin:description" content={description} />
    <meta property="linkedin:image" content={ogImageUrl} />

    <meta property="twitter:image" content={ogImageUrl} />

    <ClientRouter />
  </head>
  <body class="bg-cantabria-bg text-cantabria-text antialiased min-h-screen">
    <main
      class={cn(
        'mx-auto flex min-h-screen max-w-4xl flex-col gap-6 px-4 py-8 sm:py-10',
        className,
      )}
    >
      <slot />
      <Footer />
    </main>
  </body>
</html>
<script>
  const key = 'fcp-timestamp';
  const timestamp = localStorage.getItem(key);

  const wasMoreThan5MinutesSinceLastPing =
    timestamp && new Date(timestamp).getTime() + 5 * 60 * 1000 < Date.now();

  if (wasMoreThan5MinutesSinceLastPing) {
    fetch('/api/ping-scrapper').finally(() => {
      localStorage.setItem(key, new Date().toISOString());
    });
  }
</script>

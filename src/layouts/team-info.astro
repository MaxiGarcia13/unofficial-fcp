---
import type { Gender } from '@/types';

export interface Props {
  gender: Gender;
  group: string;
  teamName: string;
}

const { gender, group, teamName } = Astro.props;
---

<section class="flex min-w-0 flex-col gap-4 w-full mt-4">
  <div class="flex items-center gap-4">
    <a
      href={`/${gender}-${group}`}
      class="inline-flex items-center gap-2 rounded-lg border border-cantabria-border bg-cantabria-surface px-3 py-1.5 text-sm font-medium text-cantabria-text transition-colors hover:border-cantabria-red focus:outline-none focus:ring-2 focus:ring-cantabria-red/30"
    >
      <span aria-hidden="true" class="text-base leading-none">←</span>
      <span>Volver</span>
    </a>

    <h1 class="text-2xl font-semibold text-cantabria-text">{teamName}</h1>
  </div>

  <slot />
</section>

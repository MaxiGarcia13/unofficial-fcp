---
import type { Gender } from '@/types';
import GroupInfoLayout from '@/layouts/group-info.astro';

export interface Props {
  gender: Gender;
  group: string;
  teamName: string;
}

const { gender, group, teamName } = Astro.props;
---

<GroupInfoLayout gender={gender} group={group}>
  <div class="flex flex-wrap items-center gap-3 sm:gap-4">
    <a
      href={`/${gender}-${group}`}
      class="inline-flex items-center gap-2 rounded-lg border border-cantabria-border bg-cantabria-surface px-3 py-1.5 text-sm font-medium text-cantabria-text transition-colors duration-150 hover:border-cantabria-red hover:bg-cantabria-surface-secondary active:bg-cantabria-dark-muted/50 focus:outline-none focus-visible:ring-2 focus-visible:ring-cantabria-red/40 focus-visible:ring-offset-2 focus-visible:ring-offset-cantabria-bg"
    >
      <span aria-hidden="true" class="text-base leading-none">←</span>
      <span>Volver</span>
    </a>

    <h1 class="text-2xl font-semibold text-cantabria-text">{teamName}</h1>
  </div>

  <slot />
</GroupInfoLayout>

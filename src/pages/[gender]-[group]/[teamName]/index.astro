---
import type { Gender } from '@/types';
import { TeamStats } from '@/components/stats/team-stats';
import { TeamPlayersTable } from '@/components/team-players-table';
import TeamInfoLayout from '@/layouts/team-info.astro';

export const prerender = false;

interface Params {
  gender: Gender;
  group: string;
  teamName: string;
}

const { gender, group, teamName } = Astro.params as unknown as Params;
---

<TeamInfoLayout
  gender={gender}
  group={group}
  teamName={teamName}
  showGenerateAlignment
>
  <TeamPlayersTable
    client:only="react"
    gender={gender}
    group={group}
    teamName={teamName}
  />
  <TeamStats
    client:only="react"
    gender={gender}
    group={group}
    teamName={teamName}
  />
</TeamInfoLayout>

---
import type { Gender } from '@/types';
import { LineupForm } from '@/components/lineup-form';
import TeamInfoLayout from '@/layouts/team-info.astro';

export const prerender = false;

interface Params {
  gender: Gender;
  group: string;
  teamName: string;
}

const { gender, group, teamName } = Astro.params as unknown as Params;
---

<TeamInfoLayout
  gender={gender}
  group={group}
  teamName={teamName}
  title={`${teamName} - Alineación`}
  backUrl={`/${gender}-${group}/${teamName}`}
>
  <LineupForm
    client:only="react"
    gender={gender}
    group={group}
    teamName={teamName}
  />
</TeamInfoLayout>

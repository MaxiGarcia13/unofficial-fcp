---
import type { Gender } from '@/types';
import { Header } from '@/components/header';
import { TeamStatsCompare } from '@/components/stats/team-stats-compare';
import { TeamPlayersTable } from '@/components/team-players-table';
import AppLayout from '@/layouts/app.astro';
import TeamInfoLayout from '@/layouts/team-info.astro';

export const prerender = false;

interface Params {
  gender: Gender;
  group: string;
  team1: string;
  team2: string;
}

const { gender, group, team1, team2 } = Astro.params as unknown as Params;
---

<AppLayout>
  <Header gender={gender} group={group} filtersInitiallyOpen={false} />
  <TeamInfoLayout
    gender={gender}
    group={group}
    teamName={`${team1} vs ${team2}`}
  >
    <div class="flex min-w-0 flex-col gap-6 lg:flex-row lg:items-start lg:gap-6">
      <div class="min-w-0 flex-1">
        <TeamPlayersTable
          client:only="react"
          gender={gender}
          group={group}
          teamName={team1}
          variant="compare"
        />
      </div>

      <div class="min-w-0 flex-1">
        <TeamPlayersTable
          client:only="react"
          gender={gender}
          group={group}
          teamName={team2}
          variant="compare"
        />
      </div>
    </div>

    <TeamStatsCompare
      client:only="react"
      gender={gender}
      group={group}
      team1Name={team1}
      team2Name={team2}
    />
  </TeamInfoLayout>
</AppLayout>

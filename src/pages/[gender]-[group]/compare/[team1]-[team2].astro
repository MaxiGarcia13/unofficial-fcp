---
import type { Gender } from '@/types';
import { TeamStatsCompare } from '@/components/stats/team-stats-compare';
import { TeamPlayersTable } from '@/components/team-players-table';
import TeamInfoLayout from '@/layouts/team-info.astro';

export const prerender = false;

interface Params {
  gender: Gender;
  group: string;
  team1: string;
  team2: string;
}

const { gender, group, team1, team2 } = Astro.params as unknown as Params;
---

<TeamInfoLayout gender={gender} group={group} teamName={`${team1} vs ${team2}`}>
  <div class="flex gap-6">
    <TeamPlayersTable
      client:only="react"
      gender={gender}
      group={group}
      teamName={team1}
      variant="compare"
    />

    <TeamPlayersTable
      client:only="react"
      gender={gender}
      group={group}
      teamName={team2}
      variant="compare"
    />
  </div>

  <TeamStatsCompare
    client:only="react"
    gender={gender}
    group={group}
    team1Name={team1}
    team2Name={team2}
  />
</TeamInfoLayout>

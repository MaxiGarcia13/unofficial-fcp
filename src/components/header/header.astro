---
import type { Gender } from '@/types/gender';
import { Badge } from '../badge';
import { Filters } from './filters';

interface Props {
  gender?: Gender;
  group?: string;
}

const { gender, group } = Astro.props;
---

<header
  class="rounded-lg border border-cantabria-border bg-cantabria-surface p-6 shadow-sm sm:p-8"
  transition:name="header"
>
  <div class="flex flex-col gap-6">
    <div
      class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between sm:gap-6"
    >
      <div class="flex items-center gap-3 space-y-0">
        <img
          src="/favicon.png"
          alt="Liga Cántabra de Pádel"
          class="h-12 w-12 shrink-0 rounded-full object-contain sm:h-14 sm:w-14"
          width="56"
          height="56"
        />
        <h1
          class="max-w-2xl text-balance text-2xl font-bold tracking-tight text-cantabria-text sm:text-3xl"
        >
          Pádel Cantabria
        </h1>
      </div>
      <Badge>UI no oficial</Badge>
    </div>

    <div class="border-t border-cantabria-border pt-6">
      <Filters client:only="react" gender={gender} group={group} />
    </div>
  </div>
</header>

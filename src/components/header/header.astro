---
import type { Gender } from '@/types/gender';
import { FilterIcon } from '@/assets/icons/filter';
import { cn } from '@/utils/classes';
import { Filters } from './filters';

interface Props {
  gender?: Gender;
  group?: string;
  class?: string;
  filtersInitiallyOpen?: boolean;
  showFiltersToggle?: boolean;
}

const {
  gender,
  group,
  class: className,
  filtersInitiallyOpen = true,
  showFiltersToggle = true,
} = Astro.props;

const filtersPanelId = `header-filters-${Math.random().toString(36).slice(2, 10)}`;
const selectedGender = gender ?? 'MASCULINO';
const selectedGroup = group?.length ? group : 'Sin grupo';
---

<header
  class={cn(
    'rounded-lg border border-cantabria-border bg-cantabria-surface p-6 shadow-sm sm:p-8',
    className,
  )}
  transition:name="header"
>
  <div class="flex flex-col gap-6">
    <div class="flex gap-4 items-center">
      <a href="/">
        <img
          src="/favicon.png"
          alt="Liga Cántabra de Pádel"
          class="h-12 w-12 shrink-0 rounded-full object-contain sm:h-14 sm:w-14"
          width="56"
          height="56"
        />
      </a>
      <h1
        class="max-w-2xl flex-1 text-balance text-2xl font-bold tracking-tight text-cantabria-text sm:text-3xl"
      >
        Pádel Cantabria
      </h1>
      {
        showFiltersToggle && (
          <button
            type="button"
            class="rounded-lg border cursor-pointer border-cantabria-border p-2 text-cantabria-text transition-colors duration-150 hover:border-cantabria-muted hover:bg-cantabria-surface-secondary active:bg-cantabria-dark-muted/60 focus:outline-none focus-visible:ring-2 focus-visible:ring-cantabria-red/50 focus-visible:ring-offset-2 focus-visible:ring-offset-cantabria-surface"
            aria-controls={filtersPanelId}
            aria-expanded={filtersInitiallyOpen ? 'true' : 'false'}
            aria-label={
              filtersInitiallyOpen ? 'Ocultar filtros' : 'Mostrar filtros'
            }
            data-filters-toggle
            data-label-open="Ocultar filtros"
            data-label-closed="Mostrar filtros"
          >
            <FilterIcon className="h-5 w-5" />
          </button>
        )
      }
    </div>

    <div
      data-filters-summary
      class={cn(
        'border-t border-cantabria-border pt-6 text-xs font-medium text-cantabria-muted',
        filtersInitiallyOpen && 'hidden',
      )}
    >
      {selectedGender}
      {'>'}
      {selectedGroup}
    </div>

    <div
      id={filtersPanelId}
      class={cn(
        'border-t border-cantabria-border pt-6',
        !filtersInitiallyOpen && 'hidden',
      )}
    >
      <Filters client:only="react" gender={gender} group={group} />
    </div>
  </div>
</header>

<script>
  function setupFiltersToggle() {
    document.querySelectorAll('[data-filters-toggle]').forEach((toggle) => {
      if (!(toggle instanceof HTMLButtonElement)) return;

      const panelId = toggle.getAttribute('aria-controls');
      if (!panelId) return;

      const panel = document.getElementById(panelId);
      if (!panel) return;

      const summary = panel.parentElement?.querySelector(
        '[data-filters-summary]',
      );
      const setExpandedState = (expanded) => {
        panel.classList.toggle('hidden', !expanded);
        if (summary) summary.classList.toggle('hidden', expanded);

        const nextExpanded = String(expanded);
        toggle.setAttribute('aria-expanded', nextExpanded);

        const openLabel = toggle.dataset.labelOpen ?? 'Hide filters';
        const closedLabel = toggle.dataset.labelClosed ?? 'Show filters';
        const nextLabel = expanded ? openLabel : closedLabel;
        toggle.setAttribute('aria-label', nextLabel);

        const label = toggle.querySelector('[data-filters-toggle-label]');
        if (label) label.textContent = nextLabel;
      };

      // Keep DOM state in sync with server-rendered prop on load/swap.
      setExpandedState(toggle.getAttribute('aria-expanded') === 'true');

      if (toggle.dataset.toggleBound === 'true') return;
      toggle.dataset.toggleBound = 'true';

      toggle.addEventListener('click', () => {
        const isOpen = toggle.getAttribute('aria-expanded') === 'true';
        setExpandedState(!isOpen);
      });
    });
  }

  setupFiltersToggle();
  document.addEventListener('astro:page-load', setupFiltersToggle);
</script>

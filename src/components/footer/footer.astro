---
import {
  APP_VERSION,
  AUTHOR_NAME,
  LINKEDIN_URL,
  REPOSITORY_URL,
} from '@/constants/global';
---

<footer
  class="border-t border-cantabria-border/40 pt-6 text-center text-xs text-cantabria-muted"
>
  <p>
    v{APP_VERSION}
    <span class="mx-1.5 opacity-50" aria-hidden="true">·</span>
    <a
      href={REPOSITORY_URL}
      class="text-cantabria-red underline-offset-2 transition-colors duration-150 hover:text-red-300 hover:underline"
      target="_blank"
      rel="noopener noreferrer"
    >
      Repositorio
    </a>
    <span class="mx-1.5 opacity-50" aria-hidden="true">·</span>
    Creado por{' '}
    <a
      href={LINKEDIN_URL}
      class="text-cantabria-red underline-offset-2 transition-colors duration-150 hover:text-red-300 hover:underline"
      target="_blank"
      rel="noopener noreferrer"
    >
      {AUTHOR_NAME}
    </a>
  </p>
</footer>
